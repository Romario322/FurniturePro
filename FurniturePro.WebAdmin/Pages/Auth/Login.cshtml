@page
@model FurniturePro.WebAdmin.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Вход в систему";
}

<div class="login-container">
    <h2>Авторизация</h2>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <form method="post">
        <div class="form-group">
            <label asp-for="Input.Login">Логин</label>
            <input asp-for="Input.Login" class="form-control" />
            <span asp-validation-for="Input.Login" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Input.Password">Пароль</label>
            <input asp-for="Input.Password" type="password" class="form-control" />
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary">Войти</button>
    </form>
</div>