@page
@model FurniturePro.WebAdmin.Pages.Secondary.PartsModel
@{
    ViewData["Title"] = "Детали";
}

<div class="admin-page-container">
    <div class="admin-header">
        <div class="admin-header-row">
            <div class="header-block block-related">
                <div class="block-title">Связанные страницы</div>
                <div class="admin-related-links-grid">
                    <a class="admin-link-badge" asp-page="/Main/Furniture">Мебель</a>
                    <a class="admin-link-badge" asp-page="/Main/Prices">Цены</a>
                    <a class="admin-link-badge" asp-page="/Secondary/Colors">Цвета</a>
                    <a class="admin-link-badge" asp-page="/Secondary/Materials">Материалы</a>
                </div>
            </div>

            <div class="header-block block-search">
                <div class="block-title">Поиск</div>
                <div class="input-group input-group-sm admin-search-group flex-nowrap">
                    <input type="search" id="searchInput" class="form-control" placeholder="Поиск...">
                    <button class="btn btn-outline-secondary btn-clear-search btn-square" type="button" id="clearSearchText" title="Очистить">×</button>
                    <div class="btn-group view-mode-switcher" role="group">
                        <input type="radio" class="btn-check" name="searchMode" id="searchModeFilter" value="filter" checked>
                        <label class="btn btn-outline-secondary" for="searchModeFilter">Фильтр</label>
                        <input type="radio" class="btn-check" name="searchMode" id="searchModeHighlight" value="highlight">
                        <label class="btn btn-outline-secondary" for="searchModeHighlight">Выделение</label>
                    </div>
                    <button id="searchButton" type="button" class="btn btn-primary btn-search-trigger btn-square" title="Найти">🔍</button>
                </div>
            </div>

            <div class="header-block block-filters" style="min-width: 280px;">
                <div class="block-title">Фильтрация</div>
                <div class="d-flex flex-column gap-2 w-100">
                    <div class="d-flex gap-2 w-100">
                        <div class="w-50">
                            <select id="activityFilter" class="form-select form-select-sm w-100">
                                <option value="">Активность: все</option>
                            </select>
                        </div>
                        <div class="w-50">
                            <select id="colorFilter" class="form-select form-select-sm w-100">
                                <option value="">Цвет: все</option>
                            </select>
                        </div>
                    </div>
                    <div class="w-100">
                        <select id="materialFilter" class="form-select form-select-sm w-100">
                            <option value="">Материал: все</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="header-block block-actions">
                <div class="block-title">Управление</div>
                <div class="actions-column">
                    <div class="action-toolbar">
                        <button id="createPartButton" type="button" class="btn btn-sm btn-create-entity">
                            + Создать деталь
                        </button>
                        <button type="button" class="btn btn-outline-secondary" id="openImportModalBtn">
                            <i class="icon-upload"></i> Импорт
                        </button>
                    </div>
                    <div class="admin-pagination d-flex align-items-center gap-2">
                        <button id="prev" type="button" class="btn btn-outline-secondary btn-sm btn-square" title="Предыдущая страница">◄</button>
                        <span id="pageInfo"></span>
                        <button id="next" type="button" class="btn btn-outline-secondary btn-sm btn-square" title="Следующая страница">►</button>
                    </div>
                    <span id="partsCount" class="admin-count-badge">Деталей: 0</span>
                </div>
            </div>
        </div>
    </div>

    <div class="admin-table-wrapper">
        <div class="admin-table-scroll">
            <table id="partsTable" class="table table-sm table-hover align-middle mb-0 admin-table">
                <thead class="table-light">
                    <tr>
                        <th>Название</th>
                        <th>Материал</th>
                        <th>Цвет</th>
                        <th>Размеры</th>
                        <th>Вес</th>
                        <th>Активность</th>
                        <th class="col-fit">Цена</th>
                        <th class="col-fit">Описание</th>
                        <th class="col-fit">Действия</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>

    <div id="createModal" class="modal-backdrop-simple" style="display:none;">
        <div class="modal-dialog-simple">
            <div class="modal-content-simple">
                <h2 class="modal-title-simple">Создание детали</h2>
                <form id="createForm" method="post" class="modal-form-simple">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="createIsActive" name="Activity" value="true">

                    <div class="form-section">
                        <div class="form-section-title">Базовые данные</div>
                        <div class="mb-custom">
                            <label for="createName" class="form-label">Название</label>
                            <input type="text" id="createName" name="Name" class="form-control form-control-sm">
                        </div>
                        <div class="row g-2">
                            <div class="col-6">
                                <label for="createMaterial" class="form-label">Материал</label>
                                <select id="createMaterial" name="MaterialId" class="form-select form-select-sm">
                                    <option value="">Выберите...</option>
                                </select>
                            </div>
                            <div class="col-6">
                                <label for="createColor" class="form-label">Цвет</label>
                                <select id="createColor" name="ColorId" class="form-select form-select-sm">
                                    <option value="">Выберите...</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="form-section">
                        <div class="form-section-title">Габариты и Вес</div>
                        <div class="row g-2 mb-custom">
                            <div class="col-6 col-sm-3">
                                <label for="createLength" class="form-label small">Длина (мм)</label>
                                <input type="number" id="createLength" name="Length" class="form-control form-control-sm">
                            </div>
                            <div class="col-6 col-sm-3">
                                <label for="createWidth" class="form-label small">Ширина (мм)</label>
                                <input type="number" id="createWidth" name="Width" class="form-control form-control-sm">
                            </div>
                            <div class="col-6 col-sm-3">
                                <label for="createHeight" class="form-label small">Высота (мм)</label>
                                <input type="number" id="createHeight" name="Height" class="form-control form-control-sm">
                            </div>
                            <div class="col-6 col-sm-3">
                                <label for="createDiameter" class="form-label small">D (мм)</label>
                                <input type="number" id="createDiameter" name="Diameter" class="form-control form-control-sm" placeholder="Ø">
                            </div>
                        </div>
                        <div class="row g-2">
                            <div class="col-6">
                                <label for="createWeight" class="form-label">Вес (кг)</label>
                                <input type="number" id="createWeight" name="Weight" step="0.001" class="form-control form-control-sm">
                            </div>
                        </div>
                    </div>

                    <div class="form-section mb-0">
                        <div class="form-section-title">Дополнительно</div>
                        <div>
                            <label for="createDescription" class="form-label">Описание</label>
                            <textarea id="createDescription" name="Description" rows="2" class="form-control form-control-sm"></textarea>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <button type="button" class="btn btn-outline-secondary btn-sm modal-close" data-target="createModal">Отмена</button>
                        <button type="submit" class="btn btn-success btn-sm">Создать</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div id="editModal" class="modal-backdrop-simple" style="display:none;">
        <div class="modal-dialog-simple">
            <div class="modal-content-simple">
                <h2 class="modal-title-simple">Изменение детали</h2>
                <form id="editForm" method="post" class="modal-form-simple">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="editId" name="Id">

                    <div class="form-section">
                        <div class="form-section-title">Базовые данные</div>
                        <div class="mb-custom">
                            <label for="editName" class="form-label">Название</label>
                            <input type="text" id="editName" name="Name" class="form-control form-control-sm">
                        </div>
                        <div class="row g-2">
                            <div class="col-6">
                                <label for="editMaterial" class="form-label">Материал</label>
                                <select id="editMaterial" name="MaterialId" class="form-select form-select-sm">
                                    <option value="">Выберите...</option>
                                </select>
                            </div>
                            <div class="col-6">
                                <label for="editColor" class="form-label">Цвет</label>
                                <select id="editColor" name="ColorId" class="form-select form-select-sm">
                                    <option value="">Выберите...</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="form-section">
                        <div class="form-section-title">Габариты и Вес</div>
                        <div class="row g-2 mb-custom">
                            <div class="col-6 col-sm-3">
                                <label for="editLength" class="form-label small">Длина (мм)</label>
                                <input type="number" id="editLength" name="Length" class="form-control form-control-sm">
                            </div>
                            <div class="col-6 col-sm-3">
                                <label for="editWidth" class="form-label small">Ширина (мм)</label>
                                <input type="number" id="editWidth" name="Width" class="form-control form-control-sm">
                            </div>
                            <div class="col-6 col-sm-3">
                                <label for="editHeight" class="form-label small">Высота (мм)</label>
                                <input type="number" id="editHeight" name="Height" class="form-control form-control-sm">
                            </div>
                            <div class="col-6 col-sm-3">
                                <label for="editDiameter" class="form-label small">D (мм)</label>
                                <input type="number" id="editDiameter" name="Diameter" class="form-control form-control-sm" placeholder="Ø">
                            </div>
                        </div>
                        <div class="row g-2">
                            <div class="col-6">
                                <label for="editWeight" class="form-label">Вес (кг)</label>
                                <input type="number" id="editWeight" name="Weight" step="0.001" class="form-control form-control-sm">
                            </div>
                        </div>
                    </div>

                    <div class="form-section mb-0">
                        <div class="form-section-title">Дополнительно</div>
                        <div class="mb-custom">
                            <label for="editDescription" class="form-label">Описание</label>
                            <textarea id="editDescription" name="Description" rows="2" class="form-control form-control-sm"></textarea>
                        </div>

                        <div class="form-check-group">
                            <input type="checkbox" id="editIsActive" name="Activity" class="form-check-input" value="true">
                            <label for="editIsActive" class="form-check-label">Деталь активна</label>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <button type="button" class="btn btn-outline-secondary btn-sm modal-close" data-target="editModal">Отмена</button>
                        <button type="submit" class="btn btn-primary btn-sm">Сохранить</button>
                    </div>
                    <input type="hidden" name="Activity" value="false">
                </form>
            </div>
        </div>
    </div>

    <div id="deleteModal" class="modal-backdrop-simple" style="display:none;">
        <div class="modal-dialog-simple modal-dialog-compact">
            <div class="modal-content-simple modal-content-danger">
                <form id="deleteForm" method="post" class="modal-form-simple text-center">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteId" name="Id">
                    <div class="mb-3 text-danger" style="font-size: 2.5rem; line-height: 1;">⚠️</div>
                    <h2 class="modal-title-simple text-center text-danger mb-2">Удаление детали</h2>
                    <p class="mb-4 delete-modal-text small">Это действие необратимо. Вы уверены?</p>
                    <div class="d-flex justify-content-center gap-2">
                        <button type="button" class="btn btn-outline-secondary btn-sm modal-close" data-target="deleteModal">Нет, отмена</button>
                        <button type="submit" id="confirmDeleteButton" class="btn btn-danger btn-sm px-4">Да, удалить</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div id="descriptionModal" class="modal-backdrop-simple" style="display:none;">
        <div class="modal-dialog-simple">
            <div class="modal-content-simple">
                <h2 class="modal-title-simple">Описание</h2>
                <div id="descriptionContent" class="modal-description-body"></div>
                <div class="d-flex justify-content-end mt-3">
                    <button type="button" class="btn btn-outline-secondary btn-sm modal-close" data-target="descriptionModal">Закрыть</button>
                </div>
            </div>
        </div>
    </div>

    <div id="priceModal" class="modal-backdrop-simple" style="display:none;">
        <div class="modal-dialog-simple modal-dialog-compact">
            <div class="modal-content-simple">
                <h2 class="modal-title-simple">Управление ценой</h2>
                <div class="modal-part-info-box">
                    <div class="modal-part-label">Деталь</div>
                    <div id="pricePartName" class="modal-part-name">Название детали</div>
                </div>
                <form id="priceForm" method="post" class="modal-form-simple">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="pricePartId" name="PartId">
                    <div class="form-section">
                        <div class="form-section-title">Новая цена</div>
                        <div class="mb-2">
                            <label for="priceValue" class="form-label fw-bold">Стоимость (₽)</label>
                            <input type="number" id="priceValue" name="Value" step="0.01" class="form-control">
                        </div>
                        <div class="mb-2">
                            <label for="priceDate" class="form-label fw-bold">Дата установки</label>
                            <input type="datetime-local" id="priceDate" name="Date" class="form-control">
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <button type="button" class="btn btn-outline-secondary btn-sm modal-close" data-target="priceModal">Отмена</button>
                        <button type="submit" class="btn btn-success btn-sm">Установить цену</button>
                    </div>
                </form>
                <div class="mt-4 pt-3 border-top" style="border-color: var(--warm-divider) !important;">
                    <div class="modal-part-label mb-2">История изменений</div>
                    <div id="priceHistoryContainer" class="price-history-container"></div>
                </div>
            </div>
        </div>
    </div>

    <div id="importModal" class="modal-backdrop-simple" style="display:none;">
        <div class="modal-dialog-simple modal-dialog-compact">
            <div class="modal-content-simple">
                <h2 class="modal-title-simple">Импорт деталей</h2>
                <form id="importForm" method="post" class="modal-form-simple" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="form-section">
                        <div class="form-section-title">Загрузка файла</div>
                        <div class="mb-2 text-center">
                            <input type="file" id="importFileInput" name="file" class="d-none" accept=".xlsx" required />

                            <label for="importFileInput" class="file-upload-label">
                                Выбрать файл (.xlsx)
                            </label>

                            <div id="fileNameDisplay" class="file-upload-name" style="display: none;"></div>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <button type="button" class="btn btn-outline-secondary btn-sm modal-close" data-target="importModal">Отмена</button>
                        <button type="submit" class="btn btn-primary btn-sm">Загрузить</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div id="analyticsModal" class="modal-backdrop-simple" style="display:none;">
        <div class="modal-dialog-simple">
            <div class="modal-content-simple">
                <h2 class="modal-title-simple">Динамика цен</h2>
                <div class="modal-part-info-box mb-3">
                    <div class="mb-3">
                        <div class="modal-part-label">Деталь</div>
                        <div id="analyticsPartName" class="modal-part-name mb-1">Название детали</div>
                        <div id="analyticsCurrentPrice" class="fs-4 fw-bold" style="color: var(--accent-secondary);">0 ₽</div>
                    </div>
                    <div class="d-flex justify-content-between pt-2 border-top" style="border-color: var(--warm-divider) !important;">
                        <div>
                            <span class="modal-part-label d-block">Исторический минимум</span>
                            <span id="analyticsMinPrice" class="fw-bold price-stat-min">0 ₽</span>
                        </div>
                        <div class="text-end">
                            <span class="modal-part-label d-block">Исторический максимум</span>
                            <span id="analyticsMaxPrice" class="fw-bold price-stat-max">0 ₽</span>
                        </div>
                    </div>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-2 px-1">
                    <button id="analyticsPrevYear" class="btn btn-year-nav btn-square" title="Предыдущий год">◄</button>
                    <span id="analyticsYearDisplay" class="fw-bold analytics-year-text">2025</span>
                    <button id="analyticsNextYear" class="btn btn-year-nav btn-square" title="Следующий год">►</button>
                </div>
                <div class="chart-wrapper">
                    <div id="priceChart"></div>
                </div>
                <div class="d-flex justify-content-end mt-3">
                    <button type="button" class="btn btn-outline-secondary btn-sm modal-close" data-target="analyticsModal">Закрыть</button>
                </div>
            </div>
        </div>
    </div>

    <div id="errorModal" class="modal-backdrop-simple" style="display:none;">
        <div class="modal-dialog-simple modal-dialog-compact">
            <div class="modal-content-simple modal-content-error">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div class="fs-4" style="color: var(--danger-main);">⛔</div>
                    <h2 class="modal-title-simple mb-0" style="color: var(--danger-main);">Ошибки заполнения</h2>
                </div>
                <ul id="errorList" class="mb-4 error-list"></ul>
                <div class="d-flex justify-content-end">
                    <button type="button" class="btn btn-outline-secondary btn-sm modal-close" data-target="errorModal">Понятно</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" src="~/js/pages/parts.js" asp-append-version="true"></script>
}