@page
@model FurniturePro.WebAdmin.Pages.Main.PricesModel
@{
    ViewData["Title"] = "История цен";
}

<div class="admin-page-container">
    <div class="admin-header">
        <div class="admin-header-row">

            <div class="header-block block-related">
                <div class="block-title">Связанные страницы</div>
                <div class="admin-related-links-grid">
                    <a class="admin-link-badge" asp-page="/Secondary/Parts">Детали</a>
                    <a class="admin-link-badge" asp-page="/Main/Furniture">Мебель</a>
                    <a class="admin-link-badge" asp-page="/Main/Orders">Заказы</a>
                </div>
            </div>

            <div class="header-block block-search" style="flex: 1;">
                <div class="block-title">Поиск</div>

                <div class="d-flex flex-column gap-2 w-100">

                    <div class="d-flex gap-1 w-100">
                        <div id="searchContainerSingle" class="input-group input-group-sm admin-search-group flex-grow-1">
                            <input type="number" id="searchInput" class="form-control" placeholder="Поиск..." step="0.01">
                            <button class="btn btn-outline-secondary btn-clear-search btn-square" type="button" id="clearSearchText" title="Очистить">×</button>
                        </div>

                        <div id="searchContainerRange" class="input-group input-group-sm flex-grow-1" style="display: none;">
                            <span class="input-group-text bg-transparent border-0 ps-0" style="color: var(--app-text); font-weight: 500; opacity: 0.8;">₽</span>
                            <input type="number" id="searchPriceMin" class="form-control form-control-sm" placeholder="От" min="0">
                            <span class="input-group-text bg-transparent border-0" style="color: var(--app-text); font-weight: 500; opacity: 0.8;">-</span>
                            <input type="number" id="searchPriceMax" class="form-control form-control-sm" placeholder="До" min="0">
                            <button class="btn btn-outline-secondary border-start-0 btn-clear-search btn-square" type="button" id="clearSearchRange" title="Очистить">×</button>
                        </div>

                        <button id="searchButton" type="button" class="btn btn-primary btn-sm ms-1 btn-search-trigger btn-square" title="Найти">🔍</button>

                        <div class="btn-group view-mode-switcher ms-2" role="group">
                            <input type="radio" class="btn-check" name="viewMode" id="viewModeFilter" value="filter" checked>
                            <label class="btn btn-outline-secondary" for="viewModeFilter" title="Скрыть лишнее">Фильтр</label>

                            <input type="radio" class="btn-check" name="viewMode" id="viewModeHighlight" value="highlight">
                            <label class="btn btn-outline-secondary" for="viewModeHighlight" title="Подсветить найденное">Выделение</label>
                        </div>
                    </div>

                    <div class="btn-group view-mode-switcher w-100" role="group">
                        <input type="radio" class="btn-check" name="searchMethod" id="methodStart" value="start" checked>
                        <label class="btn btn-outline-secondary btn-sm flex-fill" for="methodStart">Начало</label>

                        <input type="radio" class="btn-check" name="searchMethod" id="methodExact" value="exact">
                        <label class="btn btn-outline-secondary btn-sm flex-fill" for="methodExact">Точное</label>

                        <input type="radio" class="btn-check" name="searchMethod" id="methodRange" value="range">
                        <label class="btn btn-outline-secondary btn-sm flex-fill" for="methodRange">Диапазон</label>
                    </div>
                </div>
            </div>

            <div class="header-block block-filters" style="flex: 1;">
                <div class="block-title">Фильтрация</div>
                <div class="d-flex flex-column gap-2 w-100">
                    <div class="w-100">
                        <select id="partFilter" class="form-select form-select-sm w-100">
                            <option value="">Деталь: все записи</option>
                        </select>
                    </div>
                    <div class="w-100">
                        <select id="actualityFilter" class="form-select form-select-sm w-100">
                            <option value="">Статус: Все</option>
                            <option value="actual">Только актуальные</option>
                            <option value="archived">Только архивные</option>
                        </select>
                    </div>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-transparent border-0 text-muted ps-0">📅</span>
                        <input type="text" id="dateFromFilter" class="form-control form-control-sm js-date-picker" placeholder="С..." autocomplete="off">
                        <span class="input-group-text bg-transparent border-0 text-muted">-</span>
                        <input type="text" id="dateToFilter" class="form-control form-control-sm js-date-picker" placeholder="По..." autocomplete="off">
                    </div>
                </div>
            </div>

            <div class="header-block block-actions">
                <div class="block-title">Управление</div>
                <div class="actions-column">
                    <div class="admin-pagination d-flex align-items-center gap-2 mt-auto">
                        <button id="prev" type="button" class="btn btn-outline-secondary btn-sm btn-square" title="Предыдущая страница">◄</button>
                        <span id="pageInfo"></span>
                        <button id="next" type="button" class="btn btn-outline-secondary btn-sm btn-square" title="Следующая страница">►</button>
                    </div>
                    <span id="pricesCount" class="admin-count-badge mt-2">Цен: 0 из 0</span>
                </div>
            </div>
        </div>
    </div>

    <div class="admin-table-wrapper">
        <div class="admin-table-scroll">
            <table id="pricesTable" class="table table-sm table-hover align-middle mb-0 admin-table">
                <thead class="table-light">
                    <tr>
                        <th>Деталь</th>
                        <th>Цена</th>
                        <th>Дата установки</th>
                        <th class="col-fit">Действия</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>

    <div id="editModal" class="modal-backdrop-simple" style="display:none;">
        <div class="modal-dialog-simple modal-dialog-compact">
            <div class="modal-content-simple">
                <h2 class="modal-title-simple">Изменение цены</h2>

                <form id="editForm" method="post" class="modal-form-simple">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="editId" name="Id">
                    <input type="hidden" id="editPartId" name="PartId">

                    <div class="form-section">
                        <div class="mb-3">
                            <label class="form-label fw-bold" style="color: var(--accent-secondary); text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em;">Деталь</label>
                            <div id="editPartNameDisplay" class="fs-5 fw-bold" style="color: var(--app-text);"></div>
                        </div>

                        <div class="mb-2">
                            <label for="editValue" class="form-label">Стоимость (₽)</label>
                            <input type="number" id="editValue" name="Value" step="0.01" class="form-control">
                        </div>

                        <div class="mb-2">
                            <label for="editDate" class="form-label">Дата установки</label>
                            <input type="text" id="editDate" name="Date" class="form-control js-datetime-picker" placeholder="Выберите дату и время..." autocomplete="off">
                        </div>
                    </div>

                    <div class="alert alert-warning py-2 px-3 mb-0 small d-flex align-items-center gap-2" style="background-color: rgba(243, 226, 198, 0.5); border: 1px dashed var(--warm-border); color: #856404;">
                        <span style="font-size: 1.2em;">⚠️</span>
                        <span>Вы редактируете <b>актуальную</b> цену.<br>Это повлияет на текущие расчеты.</span>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <button type="button" class="btn btn-outline-secondary btn-sm modal-close" data-target="editModal">Отмена</button>
                        <button type="submit" class="btn btn-primary btn-sm">Сохранить</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div id="deleteModal" class="modal-backdrop-simple" style="display:none;">
        <div class="modal-dialog-simple modal-dialog-compact">
            <div class="modal-content-simple modal-content-danger">
                <form id="deleteForm" method="post" class="modal-form-simple text-center">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteId" name="Id">

                    <div class="mb-3 text-danger" style="font-size: 2.5rem; line-height: 1;">⚠️</div>
                    <h2 class="modal-title-simple text-center text-danger mb-2">Удаление цены</h2>
                    <p class="mb-4 delete-modal-text small">
                        Вы удаляете <b>актуальную</b> цену.<br>
                        Предыдущая цена (если есть) станет текущей.
                    </p>

                    <div class="d-flex justify-content-center gap-2">
                        <button type="button" class="btn btn-outline-secondary btn-sm modal-close" data-target="deleteModal">Отмена</button>
                        <button type="submit" class="btn btn-danger btn-sm px-4">Удалить</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div id="errorModal" class="modal-backdrop-simple" style="display:none;">
        <div class="modal-dialog-simple modal-dialog-compact">
            <div class="modal-content-simple modal-content-error">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div class="fs-4" style="color: var(--danger-main);">⛔</div>
                    <h2 class="modal-title-simple mb-0" style="color: var(--danger-main);">Ошибка</h2>
                </div>
                <ul id="errorList" class="mb-4 error-list"></ul>
                <div class="d-flex justify-content-end">
                    <button type="button" class="btn btn-outline-secondary btn-sm modal-close" data-target="errorModal">Закрыть</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/prices.js" asp-append-version="true"></script>
}