@page
@model FurniturePro.WebAdmin.Pages.Main.OrdersModel
@{
    ViewData["Title"] = "Заказы";
}

<div class="admin-page-container">
    <div class="admin-header">
        <div class="admin-header-row">
            <div class="header-block block-related">
                <div class="block-title">Связанные страницы</div>
                <div class="admin-related-links-grid">
                    <a class="admin-link-badge" asp-page="/Main/Furniture">Мебель</a>
                    <a class="admin-link-badge" asp-page="/Main/Prices">Цены</a>
                    <a class="admin-link-badge" asp-page="/Main/Clients">Клиенты</a>
                </div>
            </div>

            <div class="header-block block-search">
                <div class="block-title">Поиск</div>
                <div class="input-group input-group-sm admin-search-group">
                    <input type="search" id="searchInput" class="form-control" placeholder="Поиск...">
                    <button class="btn btn-outline-secondary btn-clear-search btn-square" type="button" id="clearSearchText" title="Очистить">×</button>
                    <div class="btn-group search-mode-switcher" role="group">
                        <input type="radio" class="btn-check" name="searchMode" id="searchModeFilter" value="filter" checked>
                        <label class="btn btn-outline-secondary" for="searchModeFilter">Фильтр</label>
                        <input type="radio" class="btn-check" name="searchMode" id="searchModeHighlight" value="highlight">
                        <label class="btn btn-outline-secondary" for="searchModeHighlight">Выделение</label>
                    </div>
                    <button id="searchButton" type="button" class="btn btn-primary btn-search-trigger btn-square" title="Найти">🔍</button>
                </div>
            </div>

            <div class="header-block block-filters" style="min-width: 300px;">
                <div class="block-title">Фильтрация</div>
                <div class="d-flex flex-column gap-2 w-100">
                    <div class="w-100">
                        <select id="clientFilter" class="form-select form-select-sm w-100">
                            <option value="">Клиент: все</option>
                        </select>
                    </div>

                    <div class="d-flex gap-2 w-100">
                        <div class="w-50">
                            <select id="statusFilter" class="form-select form-select-sm w-100">
                                <option value="">Статус: все</option>
                            </select>
                        </div>
                        <div class="w-50">
                            <select id="groupFilter" class="form-select form-select-sm w-100">
                                <option value="">Тип: все</option>
                                <option value="action">Требуют действия</option>
                                <option value="process">В работе</option>
                                <option value="success">Успешные</option>
                                <option value="cancelled">Отмененные</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="header-block block-actions">
                <div class="block-title">Управление</div>
                <div class="actions-column">
                    <button id="createOrderButton" type="button" class="btn btn-sm btn-create-entity">
                        + Создать заказ
                    </button>
                    <div class="admin-pagination d-flex align-items-center gap-2">
                        <button id="prev" type="button" class="btn btn-outline-secondary btn-sm">◄</button>
                        <span id="pageInfo"></span>
                        <button id="next" type="button" class="btn btn-outline-secondary btn-sm">►</button>
                    </div>
                    <span id="ordersCount" class="admin-count-badge">Заказов: 0</span>
                </div>
            </div>
        </div>
    </div>

    <div class="admin-table-wrapper">
        <div class="admin-table-scroll">
            <table id="ordersTable" class="table table-sm table-hover align-middle mb-0 admin-table">
                <thead class="table-light">
                    <tr>
                        <th>Клиент</th>
                        <th>Дата создания</th>
                        <th>Статус</th>
                        <th>Сумма (без скидки)</th>
                        <th>Скидка (%)</th>
                        <th>Итого</th>
                        <th class="col-fit">Состав</th>
                        <th class="col-fit">Действия</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>

    <div id="contactsModal" class="modal-backdrop-simple" style="display:none;">
        <div class="modal-dialog-simple modal-dialog-compact">
            <div class="modal-content-simple">
                <h2 class="modal-title-simple">Контакты клиента</h2>
                <div id="contactsContent" class="modal-description-body p-3"></div>
                <div class="d-flex justify-content-end mt-3">
                    <button type="button" class="btn btn-outline-secondary btn-sm modal-close" data-target="contactsModal">Закрыть</button>
                </div>
            </div>
        </div>
    </div>

    <div id="compositionModal" class="modal-backdrop-simple" style="display:none;">
        <div class="modal-dialog-simple">
            <div class="modal-content-simple">
                <h2 class="modal-title-simple">Состав заказа</h2>
                <div id="compositionContent" class="modal-description-body" style="padding:0; border:none; background:transparent; box-shadow:none;"></div>
                <div class="d-flex justify-content-end mt-3">
                    <button type="button" class="btn btn-outline-secondary btn-sm modal-close" data-target="compositionModal">Закрыть</button>
                </div>
            </div>
        </div>
    </div>

    <div id="historyModal" class="modal-backdrop-simple" style="display:none;">
        <div class="modal-dialog-simple modal-dialog-compact">
            <div class="modal-content-simple">
                <h2 class="modal-title-simple">История статусов</h2>
                <div id="historyContent" class="modal-description-body" style="padding:0; border:none; background:transparent;"></div>
                <div class="d-flex justify-content-end mt-3">
                    <button type="button" class="btn btn-outline-secondary btn-sm modal-close" data-target="historyModal">Закрыть</button>
                </div>
            </div>
        </div>
    </div>

    <div id="createModal" class="modal-backdrop-simple" style="display:none;">
        <div class="modal-dialog-simple">
            <div class="modal-content-simple">
                <h2 class="modal-title-simple">Создание заказа</h2>
                <form id="createForm" method="post" class="modal-form-simple">
                    @Html.AntiForgeryToken()

                    <input type="hidden" id="createStatusId" name="StatusId" value="">

                    <div class="form-section mb-0">
                        <div class="form-section-title">Параметры заказа</div>

                        <div class="mb-2">
                            <label for="createClientId" class="form-label">Клиент </label>
                            <select id="createClientId" name="ClientId" class="form-select form-select-sm">
                                <option value="">Выберите клиента</option>
                            </select>
                        </div>

                        <div class="row g-2 mb-2">
                            <div class="col-md-6">
                                <label for="createDate" class="form-label">Дата начала</label>
                                <input type="text" id="createDate" name="Date" class="form-control form-control-sm" placeholder="Выберите дату..." autocomplete="off">
                                <div class="form-text mt-1" style="font-size: 0.7rem; color: var(--app-text); opacity: 0.6;">
                                    Будет создан статус "Новый"
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label for="createDiscount" class="form-label">Скидка (%)</label>
                                <input type="number" id="createDiscount" name="Discount" class="form-control form-control-sm" value="0" min="0" max="100" step="0.1">
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <button type="button" class="btn btn-outline-secondary btn-sm modal-close" data-target="createModal">Отмена</button>
                        <button type="submit" class="btn btn-success btn-sm">Создать</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div id="editModal" class="modal-backdrop-simple" style="display:none;">
        <div class="modal-dialog-simple">
            <div class="modal-content-simple">
                <h2 class="modal-title-simple">Редактирование заказа</h2>
                <form id="editForm" method="post" class="modal-form-simple">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="editId" name="Id">
                    <input type="hidden" id="editClientIdHidden" name="ClientId">
                    <input type="hidden" id="editDateHidden" name="Date">

                    <div class="form-section mb-0">
                        <div class="form-section-title">Информация (Только чтение)</div>
                        <div class="mb-2">
                            <label class="form-label" style="opacity:0.7">Клиент</label>
                            <input type="text" id="editClientNameDisplay" class="form-control form-control-sm" disabled style="background-color: rgba(0,0,0,0.02);">
                        </div>
                        <div class="mb-2">
                            <label class="form-label" style="opacity:0.7">Дата создания</label>
                            <input type="text" id="editDateDisplay" class="form-control form-control-sm" disabled style="background-color: rgba(0,0,0,0.02);">
                        </div>
                    </div>

                    <div class="form-section mb-0 mt-2">
                        <div class="form-section-title">Редактируемые поля</div>
                        <div class="mb-2">
                            <label for="editDiscount" class="form-label">Скидка (%)</label>
                            <input type="number" id="editDiscount" name="Discount" class="form-control form-control-sm" min="0" max="100" step="0.1">
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <button type="button" class="btn btn-outline-secondary btn-sm modal-close" data-target="editModal">Отмена</button>
                        <button type="submit" class="btn btn-primary btn-sm">Сохранить</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div id="deleteModal" class="modal-backdrop-simple" style="display:none;">
        <div class="modal-dialog-simple modal-dialog-compact">
            <div class="modal-content-simple modal-content-danger">
                <form id="deleteForm" method="post" class="modal-form-simple text-center">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteId" name="Id">
                    <div class="mb-3 text-danger" style="font-size: 2.5rem; line-height: 1;">⚠️</div>
                    <h2 class="modal-title-simple text-center text-danger mb-2">Удаление заказа</h2>
                    <p class="mb-4 delete-modal-text small" style="color: var(--app-text);">Это действие необратимо. Удалить заказ и его историю?</p>
                    <div class="d-flex justify-content-center gap-2">
                        <button type="button" class="btn btn-outline-secondary btn-sm modal-close" data-target="deleteModal">Нет, отмена</button>
                        <button type="submit" class="btn btn-danger btn-sm px-4">Да, удалить</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div id="changeStatusModal" class="modal-backdrop-simple" style="display:none;">
        <div class="modal-dialog-simple modal-dialog-compact">
            <div class="modal-content-simple">
                <h2 class="modal-title-simple">Изменение статуса</h2>
                <form id="changeStatusForm" class="modal-form-simple">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="changeStatusOrderId" name="IdOrder">

                    <div class="mb-3">
                        <label class="d-block small text-uppercase fw-bold mb-1" style="color: var(--app-text); opacity: 0.8; letter-spacing: 0.05em;">Текущий статус</label>
                        <div id="currentStatusDisplay" class="fw-bold fs-5"></div>
                    </div>

                    <div class="mb-3">
                        <label for="newStatusSelect" class="d-block small text-uppercase fw-bold mb-1" style="color: var(--app-text); opacity: 0.8; letter-spacing: 0.05em;">Новый статус</label>
                        <select id="newStatusSelect" name="IdStatus" class="form-select" style="font-weight: 500; color: var(--app-text);" required>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label for="changeStatusDate" class="d-block small text-uppercase fw-bold mb-1" style="color: var(--app-text); opacity: 0.8; letter-spacing: 0.05em;">Дата установки</label>
                        <input type="text" id="changeStatusDate" name="Date" class="form-control" required style="color: var(--app-text); font-weight: 500;" placeholder="Дата и время..." autocomplete="off">
                        <div class="form-text mt-1" style="font-size: 0.75rem; color: var(--app-text); opacity: 0.6; font-style: italic;">
                            Нельзя установить дату раньше предыдущего статуса.
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-outline-secondary btn-sm modal-close" data-target="changeStatusModal">Отмена</button>
                        <button type="submit" class="btn btn-primary btn-sm">Сохранить</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div id="editOrderCompositionModal" class="modal-backdrop-simple" style="display:none;">
        <div class="modal-dialog-simple" style="max-width: 1200px;">
            <div class="modal-content-simple">
                <h2 class="modal-title-simple">Редактирование состава заказа</h2>

                <div class="composition-editor-container">

                    <div class="composition-left-col">
                        <div class="panel-header">
                            <span class="panel-title">В заказе</span>
                            <span id="headerOrderTotalCount" class="badge badge-theme">0 шт.</span>
                        </div>

                        <div class="composition-table-wrapper">
                            <div class="composition-table-scroll">
                                <table class="table table-sm table-hover align-middle mb-0 admin-table" id="currentOrderCompTable">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Мебель</th>
                                            <th style="width: 70px; text-align: center;">Кол-во</th>
                                            <th style="width: 100px; text-align: right;">Сумма</th>
                                            <th class="col-fit"></th>
                                        </tr>
                                    </thead>
                                    <tbody></tbody>
                                </table>
                            </div>

                            <div class="composition-footer-row">
                                <div class="d-flex justify-content-between align-items-center w-100">
                                    <span class="fw-bold text-uppercase small" style="color: var(--app-text); letter-spacing: 0.05em;">Итого:</span>
                                    <span class="fw-bold fs-5" id="summaryOrderPrice" style="color: var(--app-text);">0,00 ₽</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="composition-right-col">
                        <div class="panel-header">
                            <span class="panel-title">Добавить мебель</span>
                        </div>

                        <div class="input-group input-group-sm mb-2" style="width: 100%;">
                            <input type="search" id="furnitureSearchInput" class="form-control" placeholder="Поиск мебели...">
                            <button class="btn btn-outline-secondary btn-clear-search btn-square" type="button" id="clearFurnitureSearch" title="Очистить">×</button>

                            <div class="btn-group search-mode-switcher" role="group">
                                <input type="radio" class="btn-check" name="furnSearchMode" id="fModeFilter" value="filter" checked>
                                <label class="btn btn-outline-secondary" for="fModeFilter">Фильтр</label>

                                <input type="radio" class="btn-check" name="furnSearchMode" id="fModeHighlight" value="highlight">
                                <label class="btn btn-outline-secondary" for="fModeHighlight">Выделение</label>
                            </div>
                        </div>

                        <div class="composition-table-wrapper">
                            <div class="composition-table-scroll">
                                <table class="table table-sm table-hover align-middle mb-0 admin-table" id="availableFurnitureTable">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Название</th>
                                            <th style="width: 80px; text-align: right;">Цена</th>
                                            <th class="col-fit"></th>
                                        </tr>
                                    </thead>
                                    <tbody></tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                </div>

                <div class="d-flex justify-content-end gap-2 mt-3">
                    <button type="button" class="btn btn-outline-secondary btn-sm modal-close" data-target="editOrderCompositionModal">Отмена</button>
                    <button type="button" id="saveCompositionBtn" class="btn btn-primary btn-sm">Сохранить изменения</button>
                </div>
            </div>
        </div>
    </div>

    <div id="errorModal" class="modal-backdrop-simple" style="display:none;">
        <div class="modal-dialog-simple modal-dialog-compact">
            <div class="modal-content-simple modal-content-error">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div class="fs-4" style="color: var(--danger-main);">⛔</div>
                    <h2 class="modal-title-simple mb-0" style="color: var(--danger-main);">Ошибки заполнения</h2>
                </div>
                <ul id="errorList" class="mb-4 error-list" style="color: var(--app-text);"></ul>
                <div class="d-flex justify-content-end">
                    <button type="button" class="btn btn-outline-secondary btn-sm modal-close" data-target="errorModal">Понятно</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/orders.js" asp-append-version="true"></script>
}