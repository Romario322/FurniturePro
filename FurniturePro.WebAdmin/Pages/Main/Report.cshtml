@page
@model FurniturePro.WebAdmin.Pages.Reports.ReportModel
@{
    ViewData["Title"] = "Аналитика продаж";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/dashboard.css" />
}

<div class="admin-page-container" style="height: calc(100vh - 60px); overflow: hidden; display: flex; flex-direction: column;">

    <div class="admin-header mb-2 flex-shrink-0">
        <div class="admin-header-row align-items-center px-3" style="min-height: 60px;">
            <div class="d-flex align-items-center gap-3 w-100">
                <h4 class="mb-0 fw-bold text-uppercase" style="color: var(--app-text); letter-spacing: 0.05em;">
                    📊 Отчет
                </h4>

                <div class="vr mx-2" style="color: var(--warm-divider);"></div>

                <div class="d-flex align-items-center gap-2">
                    <div style="width: 130px;">
                        <input type="text" id="reportDateFrom" class="form-control form-control-sm" placeholder="С..." autocomplete="off">
                    </div>

                    <span style="color: var(--app-text); opacity: 0.6;">-</span>

                    <div style="width: 130px;">
                        <input type="text" id="reportDateTo" class="form-control form-control-sm" placeholder="По..." autocomplete="off">
                    </div>

                    <div class="btn-group ms-1">
                        <button id="refreshReportBtn" class="btn btn-primary btn-sm btn-square" title="Обновить">↻</button>
                        <button id="exportReportBtn" class="btn btn-contacts btn-sm btn-square" title="Скачать PDF">📥</button>
                    </div>
                </div>

                <div class="ms-auto btn-group view-mode-switcher" role="group">
                    <input type="radio" class="btn-check" name="viewMode" id="modeHistory" value="history" checked>
                    <label class="btn btn-outline-secondary btn-sm" for="modeHistory">📈 Динамика</label>

                    <input type="radio" class="btn-check" name="viewMode" id="modeCategories" value="categories">
                    <label class="btn btn-outline-secondary btn-sm" for="modeCategories">🍩 Доли</label>

                    <input type="radio" class="btn-check" name="viewMode" id="modeTable" value="table">
                    <label class="btn btn-outline-secondary btn-sm" for="modeTable">📋 Топ продаж</label>
                </div>
            </div>
        </div>
    </div>

    <div class="content-wrapper p-0 d-flex flex-column flex-grow-1" style="overflow: hidden;">
        <div class="container-fluid h-100 p-3 d-flex flex-column">

            <div class="row g-2 mb-3 flex-shrink-0">
                <div class="col-md-3">
                    <div class="dashboard-card py-2">
                        <div class="card-icon" style="color: var(--btn-comp-bg); font-size:1.4rem; width:38px; height:38px;">💰</div>
                        <div class="card-content">
                            <div class="card-label">Выручка</div>
                            <div class="card-value fs-5" id="kpiRevenue">0 ₽</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="dashboard-card py-2">
                        <div class="card-icon" style="color: var(--danger-main); font-size:1.4rem; width:38px; height:38px;">📉</div>
                        <div class="card-content">
                            <div class="card-label">Себестоимость</div>
                            <div class="card-value fs-5" id="kpiCost">0 ₽</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="dashboard-card py-2">
                        <div class="card-icon" style="color: var(--accent-secondary); font-size:1.4rem; width:38px; height:38px;">📈</div>
                        <div class="card-content">
                            <div class="card-label">Прибыль</div>
                            <div class="card-value fs-5" id="kpiProfit">0 ₽</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="dashboard-card py-2">
                        <div class="card-icon" style="color: var(--app-text); font-size:1.4rem; width:38px; height:38px; opacity: 0.7;">📦</div>
                        <div class="card-content">
                            <div class="card-label">Заказов</div>
                            <div class="card-value fs-5" id="kpiOrders">0</div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="viewHistory" class="view-section flex-grow-1" style="min-height: 0;">
                <div class="card shadow-sm h-100" style="border: 1px solid var(--warm-border); background: var(--panel-bg); border-radius: 0.75rem;">
                    <div class="card-header bg-transparent border-bottom-0 pt-3 px-3 d-flex justify-content-between align-items-center">
                        <h6 class="text-uppercase fw-bold mb-0 chart-title">Динамика финансов</h6>
                    </div>
                    <div class="card-body p-2 position-relative" style="min-height: 0;">
                        <div id="chartHistory" style="width: 100%; height: 100%;"></div>
                    </div>
                </div>
            </div>

            <div id="viewCategories" class="view-section flex-grow-1 d-none" style="min-height: 0;">
                <div class="card shadow-sm h-100" style="border: 1px solid var(--warm-border); background: var(--panel-bg); border-radius: 0.75rem;">
                    <div class="card-header bg-transparent border-bottom-0 pt-3 px-3">
                        <h6 id="chartCatTitle" class="text-uppercase fw-bold mb-0 chart-title">Доля выручки</h6>
                    </div>
                    <div class="card-body p-2 d-flex align-items-center justify-content-center position-relative" style="min-height: 0;">
                        <div id="chartCategories" style="width: 100%; height: 100%; max-width: 800px;"></div>
                        <div id="chartCatEmpty" class="position-absolute small" style="display:none; color: var(--app-text); opacity: 0.6; font-style: italic;">Нет данных</div>
                    </div>
                </div>
            </div>

            <div id="viewTable" class="view-section flex-grow-1 d-none" style="min-height: 0;">
                <div class="card shadow-sm h-100" style="border: 1px solid var(--warm-border); background: var(--panel-bg); border-radius: 0.75rem; display: flex; flex-direction: column;">
                    <div class="card-header bg-transparent pt-3 px-3 border-bottom flex-shrink-0" style="border-color: var(--warm-border) !important;">
                        <h6 class="text-uppercase fw-bold mb-0 chart-title">Топ продаж (Мебель)</h6>
                    </div>
                    <div class="table-responsive flex-grow-1">
                        <table class="table table-hover align-middle mb-0 admin-table" id="topTable">
                            <thead class="table-light" style="position: sticky; top: 0; z-index: 5;">
                                <tr>
                                    <th style="padding-left: 1.5rem;">Название</th>
                                    <th class="text-center">Продано (шт)</th>
                                    <th class="text-end" style="padding-right: 1.5rem;">Выручка</th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script type="module" src="~/js/pages/report.js" asp-append-version="true"></script>
}